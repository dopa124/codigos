<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Guia Prático Para Conseguir um Emprego – João Victor Balaguer</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600&family=Bebas+Neue&display=swap" rel="stylesheet">
<style>
  :root {
    --navy: #0a0e2a;
    --navy2: #0d1235;
    --gold: #f0a500;
    --gold2: #ffc72c;
    --orange: #f05a00;
    --orange2: #ff7a1a;
    --red-accent: #e0394a;
    --white: #ffffff;
    --offwhite: #f5f0e8;
    --text-muted: #8891bb;
    --card-bg: rgba(255,255,255,0.04);
    --card-border: rgba(255,255,255,0.08);
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--navy);
    color: var(--white);
    font-family: 'DM Sans', sans-serif;
    overflow-x: hidden;
    line-height: 1.6;
  }

  /* HERO */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    background: radial-gradient(ellipse 120% 80% at 60% -10%, #1a2a6e 0%, var(--navy) 60%);
    overflow: hidden;
    padding: 60px 24px;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.02'%3E%3Ccircle cx='30' cy='30' r='1'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    pointer-events: none;
  }
  .hero-glow {
    position: absolute;
    width: 600px; height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(240,165,0,0.12) 0%, transparent 70%);
    top: -100px; right: -100px;
    pointer-events: none;
  }
  .hero-glow2 {
    position: absolute;
    width: 400px; height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(240,90,0,0.1) 0%, transparent 70%);
    bottom: 50px; left: -80px;
    pointer-events: none;
  }
  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 60px;
    align-items: center;
    position: relative;
    z-index: 2;
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(240,165,0,0.15);
    border: 1px solid rgba(240,165,0,0.3);
    color: var(--gold);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 100px;
    margin-bottom: 24px;
  }
  .hero-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(32px, 5vw, 60px);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 20px;
  }
  .hero-title .highlight {
    background: linear-gradient(135deg, var(--gold), var(--orange));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-subtitle {
    font-size: 17px;
    color: rgba(255,255,255,0.7);
    margin-bottom: 32px;
    max-width: 540px;
    line-height: 1.75;
  }
  .hero-proof {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 36px;
    flex-wrap: wrap;
  }
  .proof-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: rgba(255,255,255,0.6);
  }
  .proof-item .check {
    width: 20px; height: 20px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--gold), var(--orange));
    display: flex; align-items: center; justify-content: center;
    font-size: 10px;
    flex-shrink: 0;
  }
  .cta-wrap { display: flex; flex-direction: column; gap: 10px; }
  .price-old { font-size: 14px; text-decoration: line-through; color: var(--text-muted); }
  .price-big {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 48px;
    color: var(--gold);
    line-height: 1;
    display: block;
    margin-bottom: 2px;
  }
  .btn-buy {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: linear-gradient(135deg, var(--gold), var(--orange));
    color: var(--navy);
    font-family: 'DM Sans', sans-serif;
    font-size: 18px;
    font-weight: 700;
    padding: 18px 36px;
    border-radius: 12px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 8px 32px rgba(240,165,0,0.35);
    animation: pulse 2.5s ease-in-out infinite;
    max-width: 400px;
  }
  .btn-buy:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(240,165,0,0.5); }
  @keyframes pulse {
    0%, 100% { box-shadow: 0 8px 32px rgba(240,165,0,0.35); }
    50% { box-shadow: 0 8px 48px rgba(240,165,0,0.6); }
  }
  .guarantee-sm { font-size: 12px; color: rgba(255,255,255,0.4); }

  /* BOOK */
  .book-visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .book-shadow {
    position: absolute;
    bottom: -20px;
    width: 80%;
    height: 40px;
    background: radial-gradient(ellipse, rgba(240,165,0,0.25) 0%, transparent 70%);
    filter: blur(12px);
  }
  .book-img {
    width: 100%;
    max-width: 320px;
    border-radius: 10px;
    box-shadow: 20px 20px 60px rgba(0,0,0,0.7), -4px -4px 20px rgba(240,165,0,0.1);
    animation: float 4s ease-in-out infinite;
    position: relative;
    z-index: 2;
  }
  @keyframes float {
    0%, 100% { transform: translateY(0) rotate(-1deg); }
    50% { transform: translateY(-12px) rotate(1deg); }
  }
  .badge-floating {
    position: absolute;
    top: -10px; right: 0px;
    background: linear-gradient(135deg, var(--red-accent), #b0000f);
    color: white;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 13px;
    letter-spacing: 1px;
    padding: 10px;
    border-radius: 50%;
    width: 68px; height: 68px;
    display: flex; align-items: center; justify-content: center;
    text-align: center;
    line-height: 1.2;
    box-shadow: 0 4px 16px rgba(224,57,74,0.4);
    z-index: 3;
    animation: spin-slow 8s linear infinite;
  }
  @keyframes spin-slow { to { transform: rotate(360deg); } }

  /* GENERIC */
  .section-divider {
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(240,165,0,0.3), transparent);
  }
  section { padding: 80px 24px; }
  .container { max-width: 1100px; margin: 0 auto; }
  .section-label {
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 600;
    margin-bottom: 12px;
  }
  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(26px, 4vw, 44px);
    font-weight: 900;
    line-height: 1.15;
    margin-bottom: 16px;
  }
  .section-desc {
    font-size: 16px;
    color: rgba(255,255,255,0.6);
    max-width: 580px;
    line-height: 1.8;
  }

  /* PAIN */
  .pain-section { background: linear-gradient(180deg, var(--navy) 0%, var(--navy2) 100%); }
  .pain-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 16px;
    margin-top: 48px;
  }
  .pain-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 16px;
    padding: 28px 24px;
    position: relative;
    overflow: hidden;
    transition: transform 0.3s;
  }
  .pain-card:hover { transform: translateY(-4px); }
  .pain-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 3px; height: 100%;
    background: linear-gradient(180deg, var(--red-accent), transparent);
  }
  .pain-card .emoji { font-size: 28px; margin-bottom: 12px; display: block; }
  .pain-card h3 { font-size: 16px; font-weight: 600; margin-bottom: 8px; }
  .pain-card p { font-size: 14px; color: rgba(255,255,255,0.5); line-height: 1.6; }

  /* AUTHOR */
  .author-section { background: var(--navy2); }
  .author-wrap {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 60px;
    align-items: center;
  }
  .author-photo {
    width: 100%;
    aspect-ratio: 1;
    border-radius: 20px;
    background: linear-gradient(135deg, #1a2a6e, #0d1235);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 72px;
    border: 2px solid rgba(240,165,0,0.2);
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
    position: relative;
  }
  .author-cred {
    position: absolute;
    bottom: -16px;
    left: 50%;
    transform: translateX(-50%);
    background: linear-gradient(135deg, var(--gold), var(--orange));
    color: var(--navy);
    font-size: 10px;
    font-weight: 700;
    padding: 5px 14px;
    border-radius: 100px;
    white-space: nowrap;
    z-index: 10;
  }
  .author-name {
    font-family: 'Playfair Display', serif;
    font-size: 30px;
    font-weight: 900;
    margin-bottom: 4px;
  }
  .author-role { color: var(--gold); font-size: 14px; font-weight: 500; margin-bottom: 20px; }
  .author-story { font-size: 15px; color: rgba(255,255,255,0.65); line-height: 1.8; margin-bottom: 16px; }
  .author-story strong { color: var(--white); }
  .author-stats { display: flex; gap: 32px; flex-wrap: wrap; margin-top: 24px; }
  .stat-item { text-align: center; }
  .stat-num { font-family: 'Bebas Neue', sans-serif; font-size: 36px; color: var(--gold); line-height: 1; display: block; }
  .stat-label { font-size: 12px; color: rgba(255,255,255,0.4); }

  /* STEPS */
  .content-section { background: var(--navy); }
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 20px;
    margin-top: 48px;
  }
  .step-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 16px;
    padding: 28px;
    position: relative;
    transition: border-color 0.3s, transform 0.3s;
  }
  .step-card:hover { border-color: rgba(240,165,0,0.3); transform: translateY(-4px); }
  .step-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 48px;
    color: rgba(240,165,0,0.12);
    line-height: 1;
    position: absolute;
    top: 16px; right: 20px;
  }
  .step-icon { font-size: 28px; margin-bottom: 14px; display: block; }
  .step-tag {
    display: inline-block;
    background: rgba(240,165,0,0.12);
    color: var(--gold);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 100px;
    margin-bottom: 12px;
  }
  .step-card h3 { font-size: 17px; font-weight: 700; margin-bottom: 8px; }
  .step-card p { font-size: 14px; color: rgba(255,255,255,0.55); line-height: 1.7; }

  /* BONUS */
  .bonus-section {
    background: linear-gradient(135deg, var(--navy2), #0a1240);
    position: relative;
    overflow: hidden;
  }
  .bonus-section::before {
    content: 'BÔNUS';
    position: absolute;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 180px;
    color: rgba(255,255,255,0.02);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    white-space: nowrap;
    pointer-events: none;
  }
  .bonus-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 24px;
    margin-top: 48px;
    position: relative;
    z-index: 2;
  }
  .bonus-card {
    background: linear-gradient(135deg, rgba(240,165,0,0.07), rgba(240,90,0,0.04));
    border: 1px solid rgba(240,165,0,0.2);
    border-radius: 20px;
    padding: 36px 28px;
    position: relative;
    overflow: hidden;
  }
  .bonus-card::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--gold), var(--orange));
  }
  .bonus-label {
    background: linear-gradient(135deg, var(--gold), var(--orange));
    color: var(--navy);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 100px;
    display: inline-block;
    margin-bottom: 16px;
  }
  .bonus-card h3 { font-size: 20px; font-weight: 700; margin-bottom: 12px; }
  .bonus-card p { font-size: 14px; color: rgba(255,255,255,0.6); line-height: 1.7; }
  .bonus-list { list-style: none; margin-top: 16px; display: flex; flex-direction: column; gap: 8px; }
  .bonus-list li { font-size: 13px; color: rgba(255,255,255,0.6); display: flex; align-items: center; gap: 8px; }
  .bonus-list li::before { content: '✓'; color: var(--gold); font-weight: 700; flex-shrink: 0; }
  .bonus-value { margin-top: 20px; font-size: 13px; color: rgba(255,255,255,0.4); }
  .bonus-value strong { color: var(--gold); font-size: 16px; }

  /* PREVIEW */
  .preview-section { background: var(--navy); }
  .preview-scroll {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    padding: 24px 0;
    scrollbar-width: none;
    -ms-overflow-style: none;
    margin-top: 16px;
  }
  .preview-scroll::-webkit-scrollbar { display: none; }
  .preview-card {
    flex-shrink: 0;
    width: 200px;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.07);
    background: var(--navy2);
    transition: transform 0.3s, box-shadow 0.3s;
  }
  .preview-card:hover {
    transform: scale(1.05) translateY(-4px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.4), 0 0 0 1px rgba(240,165,0,0.2);
  }
  .prev-thumb {
    height: 130px;
    background: linear-gradient(135deg, #0d1235, #1a2a6e);
    display: flex; align-items: center; justify-content: center;
    flex-direction: column; gap: 8px;
  }
  .prev-thumb .icon { font-size: 32px; }
  .prev-thumb .lbl { font-size: 11px; font-weight: 700; text-align: center; padding: 0 8px; line-height: 1.4; }
  .preview-card-title { padding: 8px 12px; font-size: 11px; color: rgba(255,255,255,0.4); border-top: 1px solid rgba(255,255,255,0.06); }

  /* TESTIMONIALS */
  .testimonials { background: var(--navy2); }
  .testi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
    margin-top: 48px;
  }
  .testi-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 16px;
    padding: 28px;
  }
  .stars { color: var(--gold); font-size: 14px; margin-bottom: 14px; }
  .testi-text { font-size: 15px; color: rgba(255,255,255,0.7); line-height: 1.7; margin-bottom: 20px; font-style: italic; }
  .testi-author { display: flex; align-items: center; gap: 12px; }
  .testi-avatar {
    width: 44px; height: 44px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--gold), var(--orange));
    display: flex; align-items: center; justify-content: center;
    font-size: 18px; font-weight: 700; color: var(--navy);
    flex-shrink: 0;
  }
  .testi-name { font-size: 14px; font-weight: 600; }
  .testi-detail { font-size: 12px; color: rgba(255,255,255,0.4); }

  /* GUARANTEE */
  .guarantee-section { background: var(--navy); text-align: center; }
  .guarantee-box {
    max-width: 620px;
    margin: 40px auto 0;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(240,165,0,0.2);
    border-radius: 24px;
    padding: 48px 40px;
    position: relative;
    overflow: hidden;
  }
  .guarantee-box::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--gold), var(--orange));
  }
  .guarantee-icon { font-size: 56px; margin-bottom: 16px; display: block; }
  .guarantee-box h3 { font-family: 'Playfair Display', serif; font-size: 24px; margin-bottom: 12px; }
  .guarantee-box p { font-size: 15px; color: rgba(255,255,255,0.6); line-height: 1.7; }

  /* FINAL CTA */
  .final-cta {
    background: linear-gradient(135deg, #0d1235, #0a1540);
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .final-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(240,165,0,0.12) 0%, transparent 70%);
    pointer-events: none;
  }
  .price-tag {
    display: inline-block;
    background: rgba(240,165,0,0.1);
    border: 1px solid rgba(240,165,0,0.2);
    border-radius: 16px;
    padding: 24px 40px;
    margin: 32px auto;
  }
  .price-tag .from { font-size: 12px; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 2px; }
  .price-tag .amount { font-family: 'Bebas Neue', sans-serif; font-size: 68px; color: var(--gold); line-height: 1; }
  .price-tag .cents { font-size: 30px; vertical-align: super; }
  .price-tag .once { font-size: 13px; color: rgba(255,255,255,0.4); }
  .cta-features { display: flex; justify-content: center; gap: 24px; flex-wrap: wrap; margin: 20px 0 32px; }
  .cta-feat { display: flex; align-items: center; gap: 6px; font-size: 13px; color: rgba(255,255,255,0.6); }
  .cta-feat .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--gold); flex-shrink: 0; }
  .btn-buy-large {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    background: linear-gradient(135deg, var(--gold), var(--orange));
    color: var(--navy);
    font-family: 'DM Sans', sans-serif;
    font-size: 20px;
    font-weight: 800;
    padding: 22px 52px;
    border-radius: 14px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    box-shadow: 0 10px 40px rgba(240,165,0,0.4);
    transition: transform 0.2s, box-shadow 0.2s;
    animation: pulse 2.5s ease-in-out infinite;
  }
  .btn-buy-large:hover { transform: translateY(-3px); box-shadow: 0 16px 50px rgba(240,165,0,0.55); }
  .secure-note { margin-top: 16px; font-size: 12px; color: rgba(255,255,255,0.35); }

  /* FOOTER & SOCIAL BAR */
  footer {
    background: #060915;
    padding: 48px 24px 32px;
    text-align: center;
    border-top: 1px solid rgba(255,255,255,0.05);
  }
  .social-bar {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-bottom: 32px;
  }
  .social-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255,255,255,0.05);
    color: var(--gold);
    text-decoration: none;
    transition: all 0.3s ease;
    border: 1px solid rgba(240,165,0,0.2);
  }
  .social-icon:hover {
    background: var(--gold);
    color: var(--navy);
    transform: translateY(-4px);
    box-shadow: 0 6px 16px rgba(240,165,0,0.3);
  }
  .social-icon svg {
    width: 20px;
    height: 20px;
    fill: currentColor;
  }
  .footer-text {
    font-size: 12px;
    color: rgba(255,255,255,0.25);
  }

  /* STICKY */
  .sticky-bar {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    background: rgba(10,14,42,0.96);
    backdrop-filter: blur(16px);
    border-top: 1px solid rgba(240,165,0,0.2);
    padding: 12px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    z-index: 100;
    transform: translateY(100%);
    transition: transform 0.4s ease;
  }
  .sticky-bar.visible { transform: translateY(0); }
  .sticky-text { font-size: 14px; font-weight: 500; }
  .sticky-text span { color: var(--gold); }
  .btn-sticky {
    background: linear-gradient(135deg, var(--gold), var(--orange));
    color: var(--navy);
    font-weight: 700;
    font-size: 14px;
    padding: 10px 24px;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    text-decoration: none;
    flex-shrink: 0;
  }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    .hero-inner { grid-template-columns: 1fr; text-align: center; }
    .hero-proof { justify-content: center; }
    .cta-wrap { align-items: center; }
