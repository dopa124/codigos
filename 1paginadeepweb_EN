<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DDOS DEFENSE SYSTEM</title>
    <style>
        :root {
            --bg-color: #0d1117;
            --box-bg: #161b22;
            --text-color: #c9d1d9;
            --primary: #2ea043;
            --primary-hover: #238636;
            --error: #f85149;
            --watermark: rgba(46, 160, 67, 0.05);
            --border-color: #30363d;
        }

        body {
            margin: 0;
            padding: 0;
            background-color: var(--bg-color);
            color: var(--text-color);
            font-family: 'Courier New', Courier, monospace;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            overflow: hidden;
            position: relative;
        }

        /* Watermark Background */
        .watermark-bg {
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            pointer-events: none;
            z-index: 1;
            font-size: 2.5rem;
            font-weight: bold;
            color: var(--watermark);
            line-height: 1.5;
            word-wrap: break-word;
            text-align: justify;
            transform: rotate(-15deg);
            user-select: none;
            text-transform: uppercase;
        }

        .captcha-box {
            position: relative;
            z-index: 2;
            background-color: var(--box-bg);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 40px;
            width: 90%;
            max-width: 400px;
            text-align: center;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.7);
        }

        h1 {
            font-size: 1.4rem;
            color: #fff;
            margin-top: 0;
            margin-bottom: 10px;
            letter-spacing: 3px;
            text-transform: uppercase;
        }

        p.instruction {
            font-size: 0.85rem;
            color: #8b949e;
            margin-bottom: 25px;
        }

        .math-puzzle {
            font-size: 2rem;
            font-weight: bold;
            color: var(--primary);
            margin-bottom: 20px;
            background: #000;
            padding: 15px;
            border-radius: 4px;
            border: 1px dashed var(--border-color);
            text-shadow: 0 0 10px rgba(46, 160, 67, 0.4);
        }

        input[type="number"] {
            width: 85%;
            padding: 12px;
            font-size: 1.2rem;
            background-color: #010409;
            border: 1px solid var(--border-color);
            color: #fff;
            border-radius: 6px;
            text-align: center;
            outline: none;
            margin-bottom: 20px;
            font-family: inherit;
        }

        input[type="number"]:focus {
            border-color: var(--primary);
            box-shadow: 0 0 8px rgba(46, 160, 67, 0.5);
        }

        button {
            background-color: var(--primary);
            color: #fff;
            border: none;
            padding: 14px 24px;
            font-size: 1rem;
            font-weight: bold;
            border-radius: 6px;
            cursor: pointer;
            width: 100%;
            transition: all 0.3s ease;
            font-family: inherit;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        button:hover {
            background-color: var(--primary-hover);
            transform: translateY(-1px);
        }

        #message {
            margin-top: 15px;
            font-weight: bold;
            font-size: 0.9rem;
            min-height: 20px;
        }

        footer {
            position: absolute;
            bottom: 20px;
            z-index: 2;
            font-size: 0.75rem;
            color: #8b949e;
            text-align: center;
        }

        footer a {
            color: var(--primary);
            text-decoration: none;
        }

        footer a:hover {
            text-decoration: underline;
        }
    </style>
</head>
<body>

    <div class="watermark-bg" id="watermark"></div>

    <div class="captcha-box">
        <h1>DDOS DEFENSE</h1>
        <p class="instruction">Please solve the puzzle below to prove you are human and proceed to the requested resource.</p>
        
        <div class="math-puzzle" id="puzzle"></div>
        
        <input type="number" id="answer" placeholder="Type your answer" required>
        <button onclick="verifyCaptcha()">Verify and Access</button>
        
        <div id="message"></div>
    </div>

    <footer>
        Technical Support: <a href="mailto:cryptome0800@proton.me">cryptome0800@proton.me</a>
    </footer>

    <script>
        // REDIRECT CONFIGURATION
        // Insert your link inside the quotes below:
        const redirectLink = "https://YOUR_LINK_HERE.com";

        // Generate dynamic background text
        const backgroundWords = "BLOCK HACKS SECURE SAFE PADLOCK ".repeat(350);
        document.getElementById('watermark').textContent = backgroundWords;

        let correctAnswer = 0;

        // Generate random math puzzle
        function generatePuzzle() {
            const num1 = Math.floor(Math.random() * 25) + 10; 
            const num2 = Math.floor(Math.random() * 15) + 1;  
            
            const isAddition = Math.random() > 0.5;

            if (isAddition) {
                correctAnswer = num1 + num2;
                document.getElementById('puzzle').textContent = `${num1} + ${num2} = ?`;
            } else {
                correctAnswer = num1 - num2;
                document.getElementById('puzzle').textContent = `${num1} - ${num2} = ?`;
            }

            document.getElementById('answer').value = '';
            document.getElementById('message').textContent = '';
        }

        // Logic to verify user input
        function verifyCaptcha() {
            const userAnswer = document.getElementById('answer').value;
            const messageEl = document.getElementById('message');

            if (userAnswer === "") {
                messageEl.style.color = "var(--error)";
                messageEl.textContent = "Error: Please enter a value.";
                return;
            }

            if (parseInt(userAnswer) === correctAnswer) {
                messageEl.style.color = "var(--primary)";
                messageEl.textContent = "Access Granted! Redirecting...";
                
                // Redirect after 1.2 seconds
                setTimeout(() => {
                    window.location.href = redirectLink;
                }, 1200);
            } else {
                messageEl.style.color = "var(--error)";
                messageEl.textContent = "Verification failed. Try again.";
                // Refresh puzzle on failure
                generatePuzzle();
            }
        }

        // Submit on Enter key
        document.getElementById('answer').addEventListener('keypress', function (e) {
            if (e.key === 'Enter') {
                verifyCaptcha();
            }
        });

        // Initialize puzzle on load
        window.onload = generatePuzzle;
    </script>
</body>
</html>
